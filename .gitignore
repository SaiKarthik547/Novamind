# ============================================================================
# NovaMind .gitignore — Production-ready GitHub exclusion rules
# ============================================================================

# ── PYTHON BUILD ARTIFACTS ───────────────────────────────────────────────────
__pycache__/
*.py[cod]              # .pyc, .pyo, .pyd
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# ── TESTING & COVERAGE ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
*.cover
.nose*
pytest_cache/

# ── VIRTUAL ENVIRONMENTS ─────────────────────────────────────────────────────
venv/
.venv/
ENV/
env/
env.bak/
venv.bak/
.local/
test_env/

# ── RUNTIME & CONFIGURATION ──────────────────────────────────────────────────
.env                   # API keys and sensitive config
.env.local
.env.*.local
.novamind/             # Local runtime directory
.novamind/memory.db*   # SQLite database and WAL files
.novamind/logs/        # Runtime logs
.novamind/trash/       # Auto-backup directory
*.novamind
.memory.db
*.novamind/memory.db
# ── IDE & EDITOR ─────────────────────────────────────────────────────────────
.vscode/
.idea/
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
.env.*.swp

# ── OS-SPECIFIC ──────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/
*.test_env/
# ── TEMPORARY & CACHE ────────────────────────────────────────────────────────
*.log
*.log.*
*.pot
*.tmp
tmp/
temp/
cache/
*.bak
*.exe

# ── TESTING ARTIFACTS ────────────────────────────────────────────────────────
UserskarthAppDataLocalTemppytest_novamind/
.pytest_tmp/
test_results/
pytest_output/
scan_results.txt

# ── LLM & RUNTIME OUTPUT ─────────────────────────────────────────────────────
*.pkl
*.pickle
*.joblib
*.npy

# ── CREDENTIALS & SECRETS ────────────────────────────────────────────────────
# NEVER commit these files:
secrets.py
credentials.json
oauth2.json
*.pem
*.key
*.p8
*.p12
*.pfx

# ── BUILD OUTPUTS ────────────────────────────────────────────────────────────
*.whl
*.tar.gz
*.zip
release/

# ── SYSTEM-GENERATED ────────────────────────────────────────────────────────
.vscode-server/
.python-version

# ── SCREENSHOTS & DEBUGGING OUTPUT ───────────────────────────────────────────
screenshots/
debug_logs/
*.screenshot.png
